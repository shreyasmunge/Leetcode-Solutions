class Solution:
    def eraseOverlapIntervals(self, intervals: List[List[int]]) -> int:
        intervals.sort(key=lambda x:x[1])
        count = 0
        n=len(intervals)
        prev = intervals[0]
        for i in range(1,n):
            s,e = intervals[i]
            ps,pe = prev
            if s<pe:
                count+=1
            else:
                prev = [s,e]
        return count



        
        
