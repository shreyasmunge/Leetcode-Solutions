import heapq
class Solution:
    def minCostConnectPoints(self, points: List[List[int]]) -> int:
        visited = set()
        queue = []
        total = 0
        heapq.heappush(queue,(0,0))
        while queue:
            cost,i = heapq.heappop(queue)
            if i in visited:
                continue
            visited.add(i)
            total+=cost
            for j in range(len(points)):
                if  j not in visited:
                    mahattan = abs(points[i][0]-points[j][0])+abs(points[i][1]-points[j][1])
                    heapq.heappush(queue,(mahattan,j))
        return total


          
